SUPABASE_URL=https://segpgjvfwlwfqkverhso.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Dev mode: skip login/unlock UI and auto-sign-in (default: true)
# flutter run --dart-define=SKIP_AUTH=false  to re-enable auth
SKIP_AUTH=true
DEV_EMAIL=dev@swoosh.app
DEV_PASSWORD=swoosh-dev-local

# Set in Supabase Edge Function secrets (not in the Flutter app):
# MONZO_CLIENT_ID=
# MONZO_CLIENT_SECRET=
#
# Enable Banking — Restricted Production (personal accounts only):
# 1. Register at https://enablebanking.com and create a Production application
# 2. Select GB market; activate Restricted mode by linking/whitelisting your accounts
# 3. Download the RSA private key; set both secrets below in Supabase (Dashboard → Edge Functions → Secrets)
# ENABLE_BANKING_APP_ID=
# ENABLE_BANKING_PRIVATE_KEY=   (paste PEM; use \n for newlines if single-line)
